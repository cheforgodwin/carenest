rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasUserDoc() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasUserDoc() ? currentUser().data.accountType : null;
    }

    function isAdmin() {
      return role() == 'admin';
    }

    function isProvider() {
      return role() == 'provider' && request.auth.token.email_verified == true;
    }

    function isCustomer() {
      return role() == 'customer' && request.auth.token.email_verified == true;
    }

    function ownsUserDoc(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function validStatus(status) {
      return status in [
        'Pending',
        'Assigned',
        'In Progress',
        'Quality Check',
        'Out for Delivery',
        'Completed',
        'Complaint',
        'Cancelled'
      ];
    }

    function validPaymentStatus(status) {
      return status in ['Pending', 'Submitted', 'Paid', 'Failed', 'Refunded'];
    }

    function validPayoutStatus(status) {
      return status in ['Unpaid', 'Ready', 'Paid', 'Partial', 'Held'];
    }

    function validPaymentMethod(method) {
      return method in ['Cash', 'MTN Mobile Money', 'Orange Money'];
    }

    function validStepForStatus(status, step) {
      return (status == 'Pending' && step == 0)
        || (status == 'Assigned' && step == 1)
        || (status == 'In Progress' && step == 2)
        || (status == 'Quality Check' && step == 3)
        || (status == 'Out for Delivery' && step == 4)
        || (status == 'Completed' && step == 5)
        || (status == 'Complaint' && step == 2)
        || (status == 'Cancelled' && step == 0);
    }

    function validPrice(serviceType, itemSummary, serviceSpeed, amount) {
      return (
        serviceType == 'laundry'
        && (
          (itemSummary == 'Mixed clothes' && ((serviceSpeed == 'Normal' && amount == 3000) || (serviceSpeed == 'Express' && amount == 4500)))
          || (itemSummary == 'Shirts and trousers' && ((serviceSpeed == 'Normal' && amount == 2500) || (serviceSpeed == 'Express' && amount == 4000)))
          || (itemSummary == 'Beddings and towels' && ((serviceSpeed == 'Normal' && amount == 4500) || (serviceSpeed == 'Express' && amount == 6000)))
          || (itemSummary == 'Large family load' && ((serviceSpeed == 'Normal' && amount == 6500) || (serviceSpeed == 'Express' && amount == 8000)))
        )
      ) || (
        serviceType == 'cleaning'
        && (
          (itemSummary == 'Studio' && ((serviceSpeed == 'Standard' && amount == 5000) || (serviceSpeed == 'Deep Clean' && amount == 9000)))
          || (itemSummary == '1 Bedroom' && ((serviceSpeed == 'Standard' && amount == 7000) || (serviceSpeed == 'Deep Clean' && amount == 11000)))
          || (itemSummary == '2 Bedrooms' && ((serviceSpeed == 'Standard' && amount == 10000) || (serviceSpeed == 'Deep Clean' && amount == 14000)))
          || (itemSummary == '3+ Bedrooms' && ((serviceSpeed == 'Standard' && amount == 14000) || (serviceSpeed == 'Deep Clean' && amount == 18000)))
        )
      ) || (
        serviceType == 'delivery'
        && (
          (itemSummary == 'Groceries' && ((serviceSpeed == 'Standard' && amount == 2500) || (serviceSpeed == 'Priority' && amount == 3500)))
          || (itemSummary == 'Household essentials' && ((serviceSpeed == 'Standard' && amount == 3000) || (serviceSpeed == 'Priority' && amount == 4000)))
          || (itemSummary == 'Pharmacy' && ((serviceSpeed == 'Standard' && amount == 3500) || (serviceSpeed == 'Priority' && amount == 4500)))
          || (itemSummary == 'Custom errand' && ((serviceSpeed == 'Standard' && amount == 4500) || (serviceSpeed == 'Priority' && amount == 5500)))
        )
      );
    }

    match /users/{userId} {
      allow create: if (
          ownsUserDoc(userId)
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.accountType == 'customer'
        );

      allow get: if ownsUserDoc(userId) || isAdmin();

      allow list: if isAdmin();

      allow update: if isAdmin()
        || (
          ownsUserDoc(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'accountType',
            'uid',
            'email',
            'createdAt',
            'emailVerified',
            'emailVerifiedAt',
            'providerVerified',
            'providerVerifiedAt',
            'payoutPhoneVerified'
          ])
        )
        || (
          ownsUserDoc(userId)
          && request.auth.token.email_verified == true
          && request.resource.data.emailVerified == true
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'emailVerified',
            'emailVerifiedAt',
            'updatedAt'
          ])
        );

      allow delete: if isAdmin();
    }

    match /providerApplications/{applicationId} {
      allow create: if isCustomer()
        && applicationId == request.auth.uid
        && request.resource.data.userUid == request.auth.uid
        && request.resource.data.phone.matches('^\\+2376[0-9]{8}$')
        && request.resource.data.identityVerified == false
        && request.resource.data.payoutPhoneVerified == false
        && request.resource.data.status == 'Pending';

      allow get: if signedIn()
        && (isAdmin() || applicationId == request.auth.uid);

      allow list: if signedIn()
        && (isAdmin() || resource.data.userUid == request.auth.uid);

      allow update: if isAdmin()
        || (
          signedIn()
          && applicationId == request.auth.uid
          && resource.data.userUid == request.auth.uid
          && request.resource.data.userUid == request.auth.uid
          && request.resource.data.status == 'Pending'
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'reviewerUid',
            'reviewedAt',
            'identityVerified',
            'payoutPhoneVerified',
            'verificationReviewedBy',
            'verificationReviewedAt'
          ])
        );

      allow delete: if isAdmin();
    }

    match /serviceRequests/{requestId} {
      allow create: if signedIn()
        && isCustomer()
        && request.resource.data.keys().hasAll([
          'customerUid',
          'customerEmail',
          'serviceType',
          'serviceSpeed',
          'itemSummary',
          'amount',
          'status',
          'currentStep',
          'paymentMethod',
          'paymentStatus'
        ])
        && request.resource.data.customerUid == request.auth.uid
        && request.resource.data.status == 'Pending'
        && request.resource.data.currentStep == 0
        && request.resource.data.paymentStatus in ['Pending', 'Submitted']
        && validPaymentMethod(request.resource.data.paymentMethod)
        && validPrice(
          request.resource.data.serviceType,
          request.resource.data.itemSummary,
          request.resource.data.serviceSpeed,
          request.resource.data.amount
        )
        && !request.resource.data.keys().hasAny([
          'providerUid',
          'providerName',
          'providerEmail',
          'paidAt'
        ]);

      allow get: if signedIn()
        && (
          isAdmin()
          || resource.data.customerUid == request.auth.uid
          || resource.data.providerUid == request.auth.uid
          || (isProvider() && resource.data.status == 'Pending')
        );

      allow list: if signedIn()
        && (
          isAdmin()
          || resource.data.customerUid == request.auth.uid
          || resource.data.providerUid == request.auth.uid
          || (isProvider() && resource.data.status == 'Pending')
        );

      allow update: if (
          isAdmin()
          && validStatus(request.resource.data.status)
          && validStepForStatus(request.resource.data.status, request.resource.data.currentStep)
          && validPaymentStatus(request.resource.data.paymentStatus)
          && (
            !('payoutStatus' in request.resource.data)
            || (
              validPayoutStatus(request.resource.data.payoutStatus)
              && (
                !(request.resource.data.payoutStatus in ['Paid', 'Partial'])
                || (
                  request.resource.data.status == 'Completed'
                  && request.resource.data.paymentStatus == 'Paid'
                )
              )
            )
          )
          && request.resource.data.customerUid == resource.data.customerUid
          && request.resource.data.customerEmail == resource.data.customerEmail
          && request.resource.data.amount == resource.data.amount
          && request.resource.data.serviceType == resource.data.serviceType
          && request.resource.data.itemSummary == resource.data.itemSummary
          && request.resource.data.serviceSpeed == resource.data.serviceSpeed
        ) || (
          isProvider()
          && validStatus(request.resource.data.status)
          && validStepForStatus(request.resource.data.status, request.resource.data.currentStep)
          && request.resource.data.customerUid == resource.data.customerUid
          && request.resource.data.customerEmail == resource.data.customerEmail
          && request.resource.data.amount == resource.data.amount
          && request.resource.data.paymentStatus == resource.data.paymentStatus
          && request.resource.data.serviceType == resource.data.serviceType
          && request.resource.data.itemSummary == resource.data.itemSummary
          && request.resource.data.serviceSpeed == resource.data.serviceSpeed
          && request.resource.data.paymentMethod == resource.data.paymentMethod
          && (
            (
              resource.data.providerUid == request.auth.uid
              && (
                request.resource.data.status != 'Completed'
                || (
                  request.resource.data.completionProofText is string
                  && request.resource.data.completionProofText.size() >= 8
                )
              )
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status', 'currentStep', 'completionProofText', 'completedAt', 'updatedAt'
              ])
            )
            || (
              !('providerUid' in resource.data)
              && resource.data.status == 'Pending'
              && request.resource.data.providerUid == request.auth.uid
              && request.resource.data.status == 'Assigned'
              && request.resource.data.currentStep == 1
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'providerUid', 'providerName', 'providerEmail', 'providerPhone',
                'providerPayoutMethod', 'providerPayoutPhone',
                'status', 'currentStep', 'assignedAt', 'updatedAt'
              ])
            )
          )
        )
        || (
          isCustomer()
          && resource.data.customerUid == request.auth.uid
          && request.resource.data.customerUid == resource.data.customerUid
          && (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'customerNote', 'updatedAt'
            ])
            || (
              request.resource.data.status == 'Complaint'
              && request.resource.data.currentStep == 2
              && request.resource.data.payoutStatus == 'Held'
              && request.resource.data.complaintText is string
              && request.resource.data.complaintText.size() >= 10
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'status',
                'currentStep',
                'complaintText',
                'complaintSubmittedAt',
                'payoutStatus',
                'payoutNote',
                'updatedAt'
              ])
            )
          )
        );

      allow delete: if isAdmin();
    }

    match /paymentSmsReceipts/{receiptId} {
      allow create, update, delete: if isAdmin();
      allow get, list: if isAdmin();
    }
  }
}
